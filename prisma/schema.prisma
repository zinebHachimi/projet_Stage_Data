generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ANALYST
  VIEWER
}

enum QueryStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ContractType {
  CDI
  CDD
  FREELANCE
  INTERNSHIP
  PART_TIME
  REMOTE
  HYBRID
  UNKNOWN
}

enum KanbanPriority {
  LOW
  MEDIUM
  HIGH
}

enum ErrorSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

model User {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  email          String         @unique
  name           String?
  passwordHash   String?
  role           UserRole       @default(ANALYST)
  workspaceSlug  String         @default("default")
  queryHistories QueryHistory[]
  jobOffers      JobOffer[]
  profile        AdminProfile?
  chatMessages   ChatMessage[]
  calendarEvents CalendarEvent[]
  kanbanCards    KanbanCard[]
  errorLogs      ErrorLog[]
  chatAnalytics  ChatAnalytics[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model QueryHistory {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  userId          String      @db.ObjectId
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt          String
  normalizedQuery Json?
  status          QueryStatus @default(PENDING)
  resultCount     Int         @default(0)
  errorMessage    String?
  jobOffers       JobOffer[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

model JobOffer {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  userId         String?       @db.ObjectId
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  queryHistoryId String?       @db.ObjectId
  queryHistory   QueryHistory? @relation(fields: [queryHistoryId], references: [id], onDelete: SetNull)
  title          String
  company        String?
  city           String
  country        String        @default("Morocco")
  skills         String[]
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String        @default("MAD")
  contract       ContractType  @default(UNKNOWN)
  source         String?
  sourceUrl      String?
  aiConfidence   Float         @default(0.0)
  rawPayload     Json?
  publishedAt    DateTime?
  collectedAt    DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([city])
  @@index([contract])
  @@index([skills])
  @@index([queryHistoryId])
}

model AdminProfile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @unique @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String   @default("Admin")
  phone       String?
  location    String?
  bio         String?
  company     String?
  website     String?
  avatarUrl   String   @default("/admin-assets/images/profile/user-1.jpg")
  addressLine String?
  city        String?
  country     String   @default("Morocco")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model CalendarEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?  @db.ObjectId
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime
  color       String   @default("primary")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, startsAt])
}

model KanbanColumn {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  position  Int
  cards     KanbanCard[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([position])
}

model KanbanCard {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  columnId    String         @db.ObjectId
  column      KanbanColumn   @relation(fields: [columnId], references: [id], onDelete: Cascade)
  userId      String?        @db.ObjectId
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  title       String
  description String?
  priority    KanbanPriority @default(MEDIUM)
  imageUrl    String?
  dueDate     DateTime?
  position    Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([columnId, position])
  @@index([userId])
}

model ErrorLog {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?       @db.ObjectId
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  statusCode  Int
  title       String
  message     String
  severity    ErrorSeverity @default(ERROR)
  path        String?
  stack       String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([severity, createdAt])
  @@index([statusCode])
}

model ChatAnalytics {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  timestamp       DateTime @default(now())
  conversationId  String?
  userId          String?  @db.ObjectId
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  searchQuery     String
  normalizedQuery String?
  location        String?
  filters         Json?
  responseTime    Float    // chatbot response latency in ms
  backendLatency  Float?   // ever-jobs API request latency in ms
  resultCount     Int      // number of job results returned
  status          String   // "SUCCESS" | "FAILED" | "NO_RESULTS"
  error           String?  // error message if failed
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([conversationId])
  @@index([timestamp])
}

