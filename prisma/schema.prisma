generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ANALYST
  VIEWER
}

enum QueryStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ContractType {
  CDI
  CDD
  FREELANCE
  INTERNSHIP
  PART_TIME
  REMOTE
  HYBRID
  UNKNOWN
}

model User {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  email          String         @unique
  name           String?
  passwordHash   String?
  role           UserRole       @default(ANALYST)
  workspaceSlug  String         @default("default")
  queryHistories QueryHistory[]
  jobOffers      JobOffer[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model QueryHistory {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  userId          String      @db.ObjectId
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt          String
  normalizedQuery Json?
  status          QueryStatus @default(PENDING)
  resultCount     Int         @default(0)
  errorMessage    String?
  jobOffers       JobOffer[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

model JobOffer {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  userId         String?       @db.ObjectId
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  queryHistoryId String?       @db.ObjectId
  queryHistory   QueryHistory? @relation(fields: [queryHistoryId], references: [id], onDelete: SetNull)
  title          String
  company        String?
  city           String
  country        String        @default("Morocco")
  skills         String[]
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String        @default("MAD")
  contract       ContractType  @default(UNKNOWN)
  source         String?
  sourceUrl      String?
  aiConfidence   Float         @default(0.0)
  rawPayload     Json?
  publishedAt    DateTime?
  collectedAt    DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([city])
  @@index([contract])
  @@index([skills])
  @@index([queryHistoryId])
}
