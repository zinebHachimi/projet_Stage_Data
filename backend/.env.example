# ========================================
# Ever Jobs API — Environment Variables
# ========================================
# Copy this file to .env and fill in values.

# ── API Security ──────────────────────────
API_KEYS=                           # Comma-separated list of valid API keys
ENABLE_API_KEY_AUTH=false            # Enable API key authentication
API_KEY_HEADER_NAME=x-api-key       # Header name for API key

# ── Rate Limiting ─────────────────────────
RATE_LIMIT_ENABLED=false            # Enable rate limiting
RATE_LIMIT_REQUESTS=100             # Maximum requests per timeframe
RATE_LIMIT_TIMEFRAME=3600           # Timeframe for rate limiting (seconds)

# ── Proxy Configuration ──────────────────
DEFAULT_PROXIES=                    # Comma-separated list of proxies (user:pass@host:port)
CA_CERT_PATH=                       # Path to CA Certificate file for proxies

# ── Plugin Toggle ─────────────────────────
# Comma-separated list of source plugin ids that the discovery service should
# SKIP at registration time. Whitespace tolerated; case-insensitive. Unknown ids
# log a warning but do not block boot. See docs/PLUGIN_ARCHITECTURE.md.
EVER_JOBS_DISABLED_SOURCES=         # e.g. "linkedin, indeed"

# ── Search Defaults ──────────────────────
DEFAULT_SITE_NAMES=linkedin,indeed,zip_recruiter,glassdoor,google,bayt,naukri,bdjobs,internshala,exa,upwork
DEFAULT_RESULTS_WANTED=20           # Default number of results per site
DEFAULT_DISTANCE=50                 # Default distance in miles
DEFAULT_DESCRIPTION_FORMAT=markdown # Format of job description (markdown, html, plain)
DEFAULT_COUNTRY=USA                 # Default country for Indeed/Glassdoor

# ── Caching ───────────────────────────────
ENABLE_CACHE=false                  # Enable response caching
CACHE_EXPIRY=3600                   # Cache expiry time in seconds

# ── Logging & Environment ────────────────
LOG_LEVEL=info                      # Logging level (debug, info, warn, error)
NODE_ENV=development                # Environment name (development, production)

# ── CORS ──────────────────────────────────
CORS_ORIGINS=*                      # Allowed origins for CORS (comma-separated)

# ── Server ────────────────────────────────
PORT=3001                           # Server port

# ── API Documentation ────────────────────
ENABLE_SWAGGER=true                 # Enable Swagger UI (classic) at /swg
SWAGGER_PATH=swg                    # URL path for Swagger UI
ENABLE_SCALAR=false                 # Scalar disabled for Node 22 compatibility; use Swagger at /swg
SCALAR_PATH=docs                    # URL path for Scalar API Reference

# ── External API Keys ───────────────────
# EXA_API_KEY=                      # Exa AI search API key

# ── Upwork API ──────────────────────────
# Supports two OAuth2 flows:
#   client_credentials  — server-to-server (only clientId + clientSecret needed)
#   authorization_code  — user-delegated  (all four values needed)
# Grant type is auto-detected if UPWORK_GRANT_TYPE is omitted:
#   accessToken + refreshToken present → authorization_code, otherwise → client_credentials
# Per-request auth via input.auth.upwork overrides these env vars.
# UPWORK_CLIENT_ID=                 # OAuth2 client ID (required for both flows)
# UPWORK_CLIENT_SECRET=             # OAuth2 client secret (required for both flows)
# UPWORK_GRANT_TYPE=                # Optional: 'client_credentials' or 'authorization_code'
# UPWORK_ACCESS_TOKEN=              # OAuth2 access token (authorization_code flow only)
# UPWORK_REFRESH_TOKEN=             # OAuth2 refresh token (authorization_code flow only)

# ── USAJobs API ───────────────────────────
# USAJOBS_API_KEY=                  # API key from https://developer.usajobs.gov/APIRequest/Index
# USAJOBS_EMAIL=                    # Email used to register for USAJobs API access

# ── Adzuna API ────────────────────────────
# ADZUNA_APP_ID=                    # Application ID from https://developer.adzuna.com/signup
# ADZUNA_APP_KEY=                   # Application key from Adzuna developer portal

# ── Reed API ─────────────────────────────
# REED_API_KEY=                     # API key from https://www.reed.co.uk/developers

# ── Jooble API ───────────────────────────
# JOOBLE_API_KEY=                   # API key from https://jooble.org/api/about

# ── CareerJet API ────────────────────────
# CAREERJET_AFFID=                  # Affiliate ID from https://www.careerjet.com/partners/

# ── Phase 8: ATS Expansion API Keys ────
# FRESHTEAM_API_KEY=                # Freshteam API key (Bearer token)
# BULLHORN_CORP_TOKEN=              # Bullhorn corp token (from career portal JS)
# TRAKSTAR_API_KEY=                 # Trakstar Hire API key (Basic Auth, key as username)
# HIRINGTHING_API_KEY=              # HiringThing API key (Basic Auth)
# LOXO_API_TOKEN=                   # Loxo API token (optional, public board works without)
# FOUNTAIN_API_KEY=                 # Fountain API key (Bearer token)
# DEEL_API_TOKEN=                   # Deel API token (Bearer token)

# ── Phase 10: Government & ATS API Keys ────
# CAREERONESTOP_API_KEY=             # CareerOneStop Bearer token (free at careeronestop.org)
# CAREERONESTOP_USER_ID=             # CareerOneStop user ID (defaults to 'anonymous')
# ARBEITSAGENTUR_API_KEY=            # German Arbeitsagentur X-API-Key
# HOMERUN_API_KEY=                   # Homerun ATS Bearer token

# ── Phase 11: Developer API Keys ────────────
# FINDWORK_API_KEY=                  # FindWork.dev API token (free at findwork.dev)
# JOBDATAAPI_API_KEY=                # JobDataAPI key (optional, works without for testing)

# ── Phase 12: ATS & Niche Board API Keys ────
# AUTHENTICJOBS_API_KEY=             # Authentic Jobs API key (from authenticjobs.com/api/)
# TALENTLYFT_API_KEY=                # TalentLyft Bearer token (from TalentLyft admin)

# ── Phase 14: API-Key Sources ────────────────
# TALROO_PUBLISHER_ID=               # Talroo/Jobs2Careers publisher ID (free at talroo.com/publisher/)
# TALROO_PUBLISHER_PASS=             # Talroo/Jobs2Careers publisher password
# INFOJOBS_CLIENT_ID=                # InfoJobs OAuth client ID (free at developer.infojobs.net)
# INFOJOBS_CLIENT_SECRET=            # InfoJobs OAuth client secret

# ── Phase 15: European Government & Regional Boards ──
# JOBTECHDEV_API_KEY=                  # Swedish Employment Service API key (free at apirequest.jobtechdev.se)
# FRANCETRAVAIL_CLIENT_ID=             # France Travail OAuth2 client ID (free at francetravail.io)
# FRANCETRAVAIL_CLIENT_SECRET=         # France Travail OAuth2 client secret
# NAVJOBS_TOKEN=                       # Norwegian NAV bearer token (optional, auto-fetches public token)
