{
  "name": "@ever-jobs/root",
  "version": "0.1.0",
  "private": true,
  "description": "Ever Jobs — NestJS monorepo for multi-source job scraping",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npx nx run-many --target=build --all",
    "start:dev": "npx nx run api:start:dev",
    "cli": "npx ts-node -r tsconfig-paths/register apps/cli/src/main.ts",
    "lint": "npx nx run-many --target=lint --all",
    "test": "jest",
    "test:e2e": "jest --testPathPatterns e2e-spec",
    "test:api": "jest --testPathPatterns apps/api/__tests__",
    "test:cli": "jest --testPathPatterns apps/cli/__tests__",
    "test:sources": "jest --testPathPatterns packages/plugins/source-",
    "test:fast": "jest --testPathPatterns apps/api/__tests__/health",
    "test:scripts": "jest --testPathPatterns scripts/__tests__",
    "lint:docs": "ts-node --project tsconfig.base.json -r tsconfig-paths/register scripts/docs-lint.ts",
    "spec:next": "ts-node --project tsconfig.base.json -r tsconfig-paths/register scripts/next-spec-number.ts",
    "bench:avature": "ts-node --project tsconfig.base.json -r tsconfig-paths/register packages/plugins/source-ats-avature/__tests__/avature.bench.ts",
    "bench:gem": "ts-node --project tsconfig.base.json -r tsconfig-paths/register packages/plugins/source-ats-gem/__tests__/gem.bench.ts",
    "bench:joincom": "ts-node --project tsconfig.base.json -r tsconfig-paths/register packages/plugins/source-ats-joincom/__tests__/joincom.bench.ts",
    "bench:ats-batch-1": "npm run bench:avature && npm run bench:gem && npm run bench:joincom",
    "bench:oracle": "ts-node --project tsconfig.base.json -r tsconfig-paths/register packages/plugins/source-ats-oracle/__tests__/oracle.bench.ts",
    "bench:mercor": "ts-node --project tsconfig.base.json -r tsconfig-paths/register packages/plugins/source-ats-mercor/__tests__/mercor.bench.ts",
    "bench:tesla": "ts-node --project tsconfig.base.json -r tsconfig-paths/register packages/plugins/source-tesla/__tests__/tesla.bench.ts",
    "bench:ats-batch-2": "npm run bench:oracle && npm run bench:mercor && npm run bench:tesla"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express5": "^1.1.2",
    "@keyv/redis": "^5.1.6",
    "@nestjs/apollo": "^13.4.2",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/graphql": "^13.4.2",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.5.0",
    "@scalar/nestjs-api-reference": "^1.0.23",
    "@upwork/node-upwork-oauth2": "^2.3.0",
    "axios": "^1.16.0",
    "better-sqlite3": "^12.9.0",
    "cache-manager": "^7.2.8",
    "cacheable": "^2.3.5",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.2",
    "exa-js": "^2.3.0",
    "graphql": "^16.9.0",
    "https-proxy-agent": "^7.0.0",
    "keyv": "^5.6.0",
    "nest-commander": "^3.20.1",
    "playwright": "^1.58.2",
    "prom-client": "^15.1.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "socks-proxy-agent": "^8.0.0",
    "turndown": "^7.2.0",
    "uuid": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.3",
    "@types/turndown": "^5.0.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "nx": "^19.0.0",
    "prisma": "^6.5.0",
    "supertest": "^7.2.2",
    "testcontainers": "^10.13.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0"
  },
  "overrides": {
    "lodash": "4.18.1",
    "multer": "2.2.0",
    "qs": "6.15.2",
    "webpack": "5.106.2",
    "request": {
      "form-data": "2.5.6"
    },
    "external-editor": {
      "tmp": "0.2.7"
    },
    "openai": {
      "ws": "8.21.0"
    },
    "@nestjs/graphql": {
      "ws": "8.21.0"
    },
    "@nestjs/cli": {
      "glob": "10.5.0"
    },
    "archiver-utils": {
      "glob": "10.5.0"
    },
    "nx": {
      "minimatch": "9.0.7"
    },
    "@angular-devkit/core": {
      "picomatch": "4.0.4"
    },
    "testcontainers": {
      "undici": "6.27.0"
    },
    "express": {
      "body-parser": "1.20.5"
    },
    "@nestjs/platform-express": {
      "body-parser": "1.20.5"
    },
    "dockerode": {
      "uuid": "11.1.1"
    },
    "@apollo/server": {
      "uuid": "11.1.1"
    },
    "@eslint/eslintrc": {
      "js-yaml": "4.2.0"
    },
    "@nestjs/swagger": {
      "js-yaml": "4.2.0"
    },
    "cosmiconfig": {
      "js-yaml": "4.2.0"
    },
    "eslint": {
      "js-yaml": "4.2.0"
    }
  }
}
