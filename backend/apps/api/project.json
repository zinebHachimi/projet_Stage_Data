{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/api/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nest build api",
        "cwd": "{workspaceRoot}"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nest start api",
        "cwd": "{workspaceRoot}"
      }
    },
    "start:dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nest start api --watch",
        "cwd": "{workspaceRoot}"
      }
    },
    "start:prod": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/apps/api/main.js",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
